# Redis — Layer 1 day cache + rate limits (optional locally; recommended on Fly)
# Production: fly secrets set REDIS_URL='redis://...' (Upstash etc., same region as app)
REDIS_URL=redis://localhost:6379

# CORS origins (comma-separated, default: * for dev)
CORS_ORIGINS=*

# Sentry error tracking (leave empty to disable)
# SENTRY_DSN=https://examplePublicKey@o0.ingest.sentry.io/0
# SENTRY_TRACES_SAMPLE_RATE=0.1
# SENTRY_ENVIRONMENT=production

# Server
PORT=3000
