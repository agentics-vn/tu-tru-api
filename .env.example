# Redis connection
REDIS_URL=redis://localhost:6379

# API keys (comma-separated "key:plan" pairs)
# Example: BATTU_API_KEYS=my-secret-key:BASIC,pro-key:PRO
BATTU_API_KEYS=

# Skip auth for local dev (set to 1 to allow any API key)
# BATTU_AUTH_SKIP=1

# CORS origins (comma-separated, default: * for dev)
CORS_ORIGINS=*

# Sentry error tracking (leave empty to disable)
# SENTRY_DSN=https://examplePublicKey@o0.ingest.sentry.io/0
# SENTRY_TRACES_SAMPLE_RATE=0.1
# SENTRY_ENVIRONMENT=production

# Server
PORT=3000
